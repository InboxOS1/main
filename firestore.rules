rules_version = '2';

// InboxOS deliberately does NOT use the Firestore client SDK from the
// browser. Every read/write goes through Next.js API routes using
// firebase-admin, which bypasses these rules entirely (it authenticates
// as a service account, not as an end user). These rules exist purely
// as a safety net: even if a client Firebase config leaked, or someone
// pointed the client SDK at this project directly, no document in this
// database is reachable.
//
// If you later add client-side Firestore listeners (e.g. for live
// dashboard updates), replace the relevant `allow read: if false`
// with `if request.auth.uid == resource.data.uid` and add the
// `firebase` client Firestore SDK back to lib/firebase/client.ts.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
