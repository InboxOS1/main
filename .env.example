# ─────────────────────────────────────────────────────────────────
# FIREBASE — CLIENT (safe to expose to the browser)
# Firebase Console → Project Settings → General → Your apps → Web app
# Used only for Google Sign-In (Firebase Auth). The client never talks
# to Firestore directly — all data access goes through the server.
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────
# FIREBASE — ADMIN (server only, NEVER expose to the client)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the values from the downloaded JSON below.
# FIREBASE_PRIVATE_KEY must keep its literal \n line breaks (quoted string is fine).
# ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────────────────────────
# GOOGLE OAUTH CLIENT — for connecting Gmail inboxes (separate from
# Firebase Auth sign-in). Google Cloud Console → APIs & Services →
# Credentials → OAuth client ID → Web application.
# Enable the "Gmail API" under APIs & Services → Library first.
# Add both redirect URIs (local + prod) in the OAuth client config.
# ─────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ─────────────────────────────────────────────────────────────────
# GEMINI — Google AI Studio → Get API key
# Model is overridable; gemini-3.5-flash is the current GA default.
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ─────────────────────────────────────────────────────────────────
# APP SECRETS
# SESSION_COOKIE_SECRET / TOKEN_ENCRYPTION_KEY: any random 32+ byte
# string. Generate with: openssl rand -hex 32
# CRON_SECRET: shared secret checked on the /api/cron/* route, set
# the same value as the Vercel Cron "Authorization" bearer token.
# ─────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
